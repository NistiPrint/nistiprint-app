# ============================================
# Supabase Configuration
# ============================================
# Obtenha estas chaves em: https://app.supabase.com/project/_/settings/api

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ============================================
# Shopee Configuration
# ============================================
# Credenciais da API Shopee (Partner ID e Key)
# Obtidos em: https://partner.shopeemobile.com/

SHOPEE_PARTNER_ID=your-shopee-partner-id
SHOPEE_PARTNER_KEY=your-shopee-partner-key

# ============================================
# Worker Logging
# ============================================
WORKER_LOG_LEVEL=INFO
WORKER_LOG_FILE=/var/log/nistiprint/worker.log
WORKER_LOG_BACKUP_COUNT=30

# ============================================
# Como usar:
# ============================================
# 1. Copie este arquivo para .env
# 2. Preencha com suas credenciais do Supabase e Shopee
# 3. Execute o script:
#    python scripts/fix_orphan_vinculos.py --dry-run

# ============================================
# Comandos disponíveis:
# ============================================
# --dry-run         Apenas diagnóstico
# --create-dummies  Cria placeholders
# --remove-orphans  Remove vínculos órfãos
