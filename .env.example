# ============================================
# Supabase Configuration
# ============================================
# Obtenha estas chaves em: https://app.supabase.com/project/_/settings/api

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ============================================
# Como usar:
# ============================================
# 1. Copie este arquivo para .env
# 2. Preencha com suas credenciais do Supabase
# 3. Execute o script:
#    python scripts/fix_orphan_vinculos.py --dry-run

# ============================================
# Comandos disponíveis:
# ============================================
# --dry-run         Apenas diagnóstico
# --create-dummies  Cria placeholders
# --remove-orphans  Remove vínculos órfãos
