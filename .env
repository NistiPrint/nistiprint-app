# ===========================================
# FRONTEND - Desenvolvimento Local
# ===========================================

# Em desenvolvimento com Docker, o Vite usa proxy interno
# O proxy está configurado em vite.config.js
# Aponta para http://api:8080 dentro da rede Docker

# Supabase (opcional para auth)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# API Base URL
VITE_API_BASE_URL=/api/v2
